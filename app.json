{
  "expo": {
    "name": "Fisioterapia",
    "slug": "Fisioterapia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Fae_Logo.jpg",
    "scheme": "Fisioterapia",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
   
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fff",
          "dark": {
            "backgroundColor": "#fff"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
